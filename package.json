{
  "name": "vitals-db",
  "version": "0.10.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check .",
    "check:ci": "biome check --error-on-warnings .",
    "typecheck": "tsc -b --pretty",
    "test": "bun test",
    "build": "bun run typecheck && bun run build:web",
    "build:web": "bun run --filter @vitals/web build",
    "verify": "bun run check:ci && bun run typecheck && bun run test",
    "health": "bun apps/server/src/cli.ts",
    "fixture": "bun scripts/gen-fixture.ts",
    "postinstall": "lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "1.1.14",
    "lefthook": "1.8.2",
    "typescript": "5.6.3"
  }
}
